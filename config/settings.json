	//  - always: Tool calls are always collapsed, even without thinking.
	"chat.agent.thinking.collapsedTools": "always",

	// Controls whether to use an LLM to generate summary titles for thinking sections.
	"chat.agent.thinking.generateTitles": true,

	// Customize the loading messages shown during agent thinking and progress indicators. Use `"mode": "replace"` to use only your phrases, or `"mode": "append"` to add them to the defaults.
	"chat.agent.thinking.phrases": {
		"mode": "append",
		"phrases": []
	},

	// When enabled, terminal tool calls are displayed inside the thinking dropdown with a simplified view.
	"chat.agent.thinking.terminalTools": true,

	// Controls how thinking is rendered.
	//  - collapsed: Thinking parts will be collapsed by default.
	//  - collapsedPreview: Thinking parts will be expanded first, then collapse once we reach a part that is not thinking.
