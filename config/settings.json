	"cmake.ctest.debugLaunchTarget": null,

	// Regular expressions for searching CTest output for additional details about failures. All patterns are tried and test failure details from each are collected.
	// 
	// Patterns must have at minimum one capture group to match the name of the `file` where the failure occurred. They can optionally also capture `line`, `message`, `expected`, and `actual`.
	// 
	// For example, to match a failure line like `path/to/file:47: text of error message`, this pattern matcher could be used:
	// ```json
	// {
	//   "regexp": "(.+):(\\d+): ?(.*)",
	//   "file": 1,
	//   "line": 2,
	//   "message": 3
	// }
	// ```
	// 
	"cmake.ctest.failurePatterns": [
		{
			"regexp": "(.*?):(\\d+): *(?:error: *)(.*)"
		},
		{
			"regexp": "(.*?)\\((\\d+)\\): *(?:error: *)(.*)"
		},
		{
			"regexp": "(.*?):(\\d+): *(Failure.*)"
		}
	],

